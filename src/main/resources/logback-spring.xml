<?xml version="1.0" encoding="UTF-8"?>
<configuration debug="true">
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <property name="LOG_FILE" value="${LOG_FILE:-${LOG_PATH:-${LOG_TEMP:-${java.io.tmpdir:-/tmp}}/}/audit.log}"/>
    
    <!-- Target appender for async wrappers: ROLLING_FILE or CONSOLE -->
    <property name="TARGET_APPENDER" value="ROLLING_FILE"/>

    <!-- Compact console appender for benchmarking (minimal pattern) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%m%n</pattern>
        </encoder>
    </appender>

    <appender name="ROLLING_FILE" class="com.example.auditing.logging.FsyncRollingFileAppender">
        <file>${LOG_FILE}</file>
        <fsyncEnabled>true</fsyncEnabled>
        <immediateFlush>true</immediateFlush>
        <encoder>
            <pattern>%m%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>500MB</maxFileSize>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- Standard AsyncAppender (default) -->
    <springProfile name="!disruptor">
        <appender name="ASYNC" class="ch.qos.logback.classic.AsyncAppender">
            <appender-ref ref="${TARGET_APPENDER}" />
            <neverBlock>false</neverBlock>
            <discardingThreshold>0</discardingThreshold>
            <queueSize>1</queueSize>
            <includeCallerData>false</includeCallerData>
        </appender>

        <root level="WARN">
            <appender-ref ref="ASYNC"/>
        </root>
    </springProfile>

    <!-- LoggingEventAsyncDisruptorAppender (activate with spring.profiles.active=disruptor) -->
    <springProfile name="disruptor">
        <appender name="ASYNC_DISRUPTOR" class="net.logstash.logback.appender.LoggingEventAsyncDisruptorAppender">
            <appender-ref ref="${TARGET_APPENDER}" />
            <ringBufferSize>65536</ringBufferSize>
            <producerType>multi</producerType>
            <waitStrategyType>blocking</waitStrategyType>
            <appendTimeout>-1</appendTimeout>
            <droppedWarnFrequency>1</droppedWarnFrequency>
        </appender>

        <root level="WARN">
            <appender-ref ref="ASYNC_DISRUPTOR"/>
        </root>
    </springProfile>
</configuration>